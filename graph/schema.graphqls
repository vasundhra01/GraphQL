}

type Query {
    users: [User!]!
    user(id: ID!): User
    deviceInstances: [DeviceInstance!]!
    deviceInstance(id: ID!): DeviceInstance
    deviceModels: [DeviceModel!]!
    deviceModel(id: ID!): DeviceModel
    sensors: [Sensor!]!
    sensor(id: ID!): Sensor
    batches: [Batch!]!
    batch(id: ID!): Batch
    clients: [Client!]!
    client(id: ID!): Client
    costs: [Cost!]!
    cost(id: ID!): Cost
    sites: [Site!]!
    site(id: ID!): Site
    gateways: [Gateway!]!
    gateway(id: ID!): Gateway
    gatewayInstances: [GatewayInstance!]!
    gatewayInstance(id: ID!): GatewayInstance
    alarmConfigurations: [AlarmConfiguration!]!
    alarmConfiguration(id: ID!): AlarmConfiguration
    billMasters: [BillMaster!]!
    billMaster(id: ID!): BillMaster
    emailGateways: [EmailGateway!]!
    emailGateway(id: ID!): EmailGateway
    workGroups: [WorkGroup!]!
    workGroup(id: ID!): WorkGroup
    smartMeterConfigurations: [SmartMeterConfiguration!]!
    smartMeterConfiguration(id: ID!): SmartMeterConfiguration
}


    tolerenceValue: Float
}

type Rule {
    condition: String!
    leftHandSide: RuleLeftHandSide!
    resetValue: RuleResetValue!
    rightHandSide: RuleRightHandSide!
}

type RuleSet {
    ruleAndOrOperationData: RuleSetAndOrOperationData!
